@page "/ProductDetails"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<OnlineShopBlazor.Models.Db.OnlineShopContext> DbFactory
@inject NavigationManager NavigationManager

<!--breadcrumbs area start-->

<style>
    .carousel-control-next span, .carousel-control-prev span {
                    background-color: orange;
                }

                .carousel-control-next, .carousel-control-prev {
                    width: auto;
                }
</style>
<div class="breadcrumbs_area breadcrumbs_product" style="margin-top:100px;">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="breadcrumb_content">
                    <ul>
                        <li><a href="/">home</a></li>
                        <li><a href="/shop">shop</a></li>
                        <li>@Product.Title</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
<!--breadcrumbs area end-->
<!--product details start-->
<section class="product_details mb-135">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="product_zoom_gallery">
                    <OnlineShopBlazor.Components.Pages.Common.ProductDetailsImageSlider Galleries="@Galleries" ImageName="@Product.ImageName" />
                </div>
            </div>
            <div class="col-lg-6 col-md-6">
                <div class="product_d_right">
                    <form action="#">
                        <h1>@Product.Title</h1>
                        <div class="product_ratting_review d-flex align-items-center">
                            <div class="product_review">
                                <ul class="d-flex">
                                    <li>@CommentsCount reviews</li>
                                    <li>Write your review</li>
                                </ul>
                            </div>
                        </div>
                        @if (Product.Discount != null && Product.Discount > 0)
                        {
                            <div class="price_box">
                                @{
                                    decimal? discounted_price;
                                    discounted_price = Product.Price.GetValueOrDefault(0) - Product.Discount.GetValueOrDefault(0);
                                }
                                <span class="current_price">
                                    $@discounted_price.GetValueOrDefault(0).ToString("F")
                                </span>
                                <span class="old_price">
                                    $@Product.Price.GetValueOrDefault(0).ToString("F")
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="price_box">
                                <span class="current_price">$@Product.Price.GetValueOrDefault(0).ToString("F")</span>
                            </div>
                        }
                        <div class="product_availalbe">
                            <ul class="d-flex">
                                <li><i class="icon-layers icons"></i> Only <span>@Product.Qty</span> left </li>
                                <li>
                                    Availalbe:
                                    @if (Product.Qty > 0)
                                    {
                                        <span class="stock">In Stock</span>
                                    }
                                    else
                                    {
                                        <span class="stock text-danger">No</span>
                                    }

                                </li>
                            </ul>
                        </div>
                        <div class="product_desc">
                            <p> @Product.Description</p>
                        </div>
                        <div class="product_variant">

                            <div class="variant_quantity_btn d-flex">
                                @if (Product.Qty>0)
                                {
                                    <OnlineShopBlazor.Components.Pages.Common.AddToCartButtonComponent ProductId="Product.Id" />
                                }
                            </div>
                        </div>
                        <div class="product_sku">
                            <p><span>SKU: </span> #PRI @Product.Id</p>
                        </div>
                        <div class="product_tags d-flex">
                            @if (!string.IsNullOrEmpty(Product.Tags))
                            {
                                var tags = Product.Tags.Split(",");
                                <span>tags: </span>
                                <ul class="d-flex">
                                    @foreach (var item in tags)
                                    {
                                        <li><a href="/shop?SearchText=@item">@item,</a></li>
                                    }


                                </ul>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
<!--product details end-->
<!--product info start-->
<div class="product_d_info mb-118">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="product_d_inner">
                    <div class="product_info_button border-bottom">
                        <OnlineShopBlazor.Components.Pages.Common.ProductDetailsTabComp Product="@Product"/>
                      
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--product info end-->
<!--product area start-->
<section class="product_area related_products mb-118">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="section_title mb-50">
                    <h2>New Products</h2>
                </div>
            </div>
        </div>
        <div class="product_container row">
            <OnlineShopBlazor.Components.Pages.Common.NewProductsComponent />
        </div>
    </div>
</section>
<!--product area end-->

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    private Product? Product { get; set; } = new();
    private List<ProductGallery> Galleries { get; set; } = new();
    public int CommentsCount { get; set; }
    protected override async Task OnInitializedAsync()
    {

        using var dbContext = DbFactory.CreateDbContext();

        Product = await dbContext.Products.FirstOrDefaultAsync(x => x.Id == Id);

        if (Product == null)
        {
            NavigationManager.NavigateTo("notfound");
        }
        Galleries = dbContext.ProductGalleries.Where(x => x.ProductId == Product.Id).ToList();
        //-------------
        CommentsCount = dbContext.Comments.Count(x => x.ProductId == Product.Id);
    }
}