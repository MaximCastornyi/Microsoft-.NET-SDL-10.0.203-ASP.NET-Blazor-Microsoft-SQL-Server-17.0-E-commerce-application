@page "/comments/create"
@using Microsoft.EntityFrameworkCore
@using OnlineShopBlazor.Models.Db
@inject IDbContextFactory<OnlineShopBlazor.Models.Db.OnlineShopContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Comment</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Comment" OnValidSubmit="AddComment" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert"/>
            <div class="mb-3">
                <label for="name" class="form-label">Name:</label> 
                <InputText id="name" @bind-Value="Comment.Name" class="form-control" /> 
                <ValidationMessage For="() => Comment.Name" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="email" class="form-label">Email:</label> 
                <InputText id="email" @bind-Value="Comment.Email" class="form-control" /> 
                <ValidationMessage For="() => Comment.Email" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="commenttext" class="form-label">CommentText:</label> 
                <InputText id="commenttext" @bind-Value="Comment.CommentText" class="form-control" /> 
                <ValidationMessage For="() => Comment.CommentText" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="productid" class="form-label">ProductId:</label> 
                <InputNumber id="productid" @bind-Value="Comment.ProductId" class="form-control" /> 
                <ValidationMessage For="() => Comment.ProductId" class="text-danger" /> 
            </div>        
            <div class="mb-3">
                <label for="createdate" class="form-label">CreateDate:</label> 
                <InputDate id="createdate" @bind-Value="Comment.CreateDate" class="form-control" /> 
                <ValidationMessage For="() => Comment.CreateDate" class="text-danger" /> 
            </div>        
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/comments">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    private Comment Comment { get; set; } = default!;

    protected override void OnInitialized() => Comment ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task AddComment()
    {
        using var context = DbFactory.CreateDbContext();
        context.Comments.Add(Comment);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/comments");
    }
}
